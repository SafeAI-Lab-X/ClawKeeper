{
  "principles": [
    "external-text-is-not-authority",
    "secrets-are-need-to-know",
    "side-effects-need-explicit-justification",
    "restore-boundaries-before-velocity",
    "freeze-then-explain-on-anomaly"
  ],
  "riskySandboxModes": [
    "danger-full-access",
    "disabled",
    "off"
  ],
  "riskyApprovalModes": [
    "never",
    "auto"
  ],
  "trustedGatewayBinds": [
    "127.0.0.1",
    "localhost"
  ],
  "skillRiskPatterns": [
    {
      "id": "shell.remote-pipe",
      "severity": "HIGH",
      "target": "script",
      "mode": "regex",
      "pattern": "curl\\s+[^\\n|]+\\|\\s*(bash|sh)",
      "title": "Remote script direct pipe execution",
      "remediation": "Download first, verify cryptographic signatures, then execute instead."
    },
    {
      "id": "shell.force-delete",
      "severity": "HIGH",
      "target": "script",
      "mode": "regex",
      "pattern": "rm\\s+-rf\\s+(/|~|\\$HOME|\\.)",
      "title": "High-risk recursive deletion",
      "remediation": "Restrict deletion scope to specific directories and add explicit path validation."
    },
    {
      "id": "shell.secret-read",
      "severity": "MEDIUM",
      "target": "script",
      "mode": "regex",
      "pattern": "(cat|grep|sed)[^\\n]*(\\.env|id_rsa|credentials?)",
      "title": "Script directly reads sensitive files",
      "remediation": "Minimize sensitive reads to necessary fields only and document the purpose."
    },
    {
      "id": "prompt.override-authority",
      "severity": "MEDIUM",
      "target": "skill",
      "mode": "substring",
      "pattern": "ignore previous instructions",
      "title": "Typical privilege escalation prompt detected",
      "remediation": "Remove prompts that override system boundaries or authorization rules."
    },
    {
      "id": "prompt.secret-export",
      "severity": "HIGH",
      "target": "skill",
      "mode": "substring",
      "pattern": "send secrets",
      "title": "Skill text encourages sensitive information export",
      "remediation": "Remove sensitive exfiltration instructions and use minimal read-only access instead."
    },
    {
      "id": "script.dynamic-launch",
      "severity": "HIGH",
      "target": "script",
      "mode": "regex",
      "pattern": "(eval\\s*\\(|exec\\s*\\(|os\\.system\\s*\\(|child_process\\.(exec|spawn)\\s*\\()",
      "title": "Script contains dynamic execution entry points",
      "remediation": "Use explicit command whitelist instead of dynamic string concatenation for execution."
    },
    {
      "id": "script.identity-tamper",
      "severity": "MEDIUM",
      "target": "script",
      "mode": "regex",
      "pattern": "(SOUL\\.md|AGENTS\\.md|TOOLS\\.md|openclaw\\.json)",
      "title": "Script attempts to modify agent identity or core configuration",
      "remediation": "Add purpose documentation, scope restrictions, and explicit user confirmation for configuration modifications."
    },
    {
      "id": "script.env-exfil-hint",
      "severity": "HIGH",
      "target": "script",
      "mode": "regex",
      "pattern": "(curl|wget|nc)[^\\n]*(\\.env|credentials?|token|auth)",
      "title": "Script shows signs of sensitive data exfiltration",
      "remediation": "Separate network transmission from sensitive read logic and block default exfiltration paths."
    },
    {
      "id": "skill.boundary-rewrite",
      "severity": "MEDIUM",
      "target": "skill",
      "mode": "regex",
      "pattern": "(forget .*above|switch .*mode|new role|do not alert|keep .*secret)",
      "title": "Skill text attempts to rewrite boundaries or hide execution",
      "remediation": "Remove statements that change boundary sources or require concealment of actions."
    },
    {
      "id": "skill.hidden-payload",
      "severity": "MEDIUM",
      "target": "skill",
      "mode": "regex",
      "pattern": "(base64:|data:text/plain;base64|\\\\u200[bcd]|\\\\ufeff|display:none|opacity:0)",
      "title": "Skill text contains hidden payload indicators",
      "remediation": "Remove hidden content or encoding wrappers and use visible, reviewable text instead."
    }
  ],
  "suspiciousSkillNames": [
    "wallet",
    "updater",
    "security-tool",
    "patch",
    "installer"
  ],
  "dangerousPrerequisitePatterns": [
    "disable gatekeeper",
    "sudo bash",
    "paste this into terminal",
    "grant full disk access",
    "turn off quarantine"
  ],
  "protectedPaths": [
    { "pattern": "~/.ssh/**",                   "severity": "CRITICAL", "reason": "SSH keys and config" },
    { "pattern": "~/.gnupg/**",                 "severity": "CRITICAL", "reason": "GPG keys" },
    { "pattern": "~/.aws/credentials",          "severity": "CRITICAL", "reason": "AWS credentials" },
    { "pattern": "~/.aws/config",               "severity": "HIGH",     "reason": "AWS profile config" },
    { "pattern": "~/.netrc",                    "severity": "CRITICAL", "reason": "Network auth tokens" },
    { "pattern": "~/.docker/config.json",       "severity": "HIGH",     "reason": "Docker registry auth" },
    { "pattern": "~/.kube/config",              "severity": "CRITICAL", "reason": "Kubernetes cluster credentials" },
    { "pattern": "~/.config/gh/**",             "severity": "HIGH",     "reason": "GitHub CLI auth" },
    { "pattern": "~/.config/gcloud/**",         "severity": "HIGH",     "reason": "Google Cloud credentials" },
    { "pattern": "~/.gitconfig",                "severity": "HIGH",     "reason": "Git global identity" },
    { "pattern": "~/.bashrc",                   "severity": "HIGH",     "reason": "Shell startup file" },
    { "pattern": "~/.bash_profile",             "severity": "HIGH",     "reason": "Shell startup file" },
    { "pattern": "~/.zshrc",                    "severity": "HIGH",     "reason": "Shell startup file" },
    { "pattern": "~/.profile",                  "severity": "HIGH",     "reason": "Shell startup file" },
    { "pattern": "~/.openclaw/openclaw.json",   "severity": "HIGH",     "reason": "OpenClaw core config" },
    { "pattern": "~/.openclaw/AGENTS.md",       "severity": "HIGH",     "reason": "Agent runtime constitution" },
    { "pattern": "~/.openclaw/SOUL.md",         "severity": "HIGH",     "reason": "Agent soul file" },
    { "pattern": "/etc/shadow",                 "severity": "CRITICAL", "reason": "System password hashes" },
    { "pattern": "/etc/sudoers",                "severity": "CRITICAL", "reason": "Sudo privilege config" },
    { "pattern": "/etc/sudoers.d/**",           "severity": "CRITICAL", "reason": "Sudo privilege config" },
    { "pattern": "/etc/passwd",                 "severity": "HIGH",     "reason": "System user database" },
    { "pattern": "/etc/ssh/**",                 "severity": "CRITICAL", "reason": "System SSH config" },
    { "pattern": "~/.openclaw/workspace/clawkeeper/.hmac-key", "severity": "CRITICAL", "reason": "Clawkeeper permission HMAC key" }
  ],
  "budgetGuard": {
    "enabled": true,
    "unlimited": true,
    "windowDays": 1,
    "warnRatio": 0.8,
    "limits": {
      "input": 1000000,
      "output": 500000,
      "total": 1500000
    }
  },
  "inputValidator": {
    "enabled": true,
    "failurePolicy": "fail-open",
    "unknownToolPolicy": "pass"
  },
  "pathGuard": {
    "enabled": true,
    "failurePolicy": "fail-closed",
    "bashLikeTools": ["bash", "shell", "exec", "command", "run_command", "execute_command", "terminal"]
  },
  "executionGate": {
    "enabled": true,
    "failurePolicy": "fail-closed",
    "bashLikeTools": ["bash", "shell", "exec", "command", "run_command", "execute_command", "terminal"],
    "dangerousCommands": [
      {
        "id": "exec.rm-rf-root",
        "severity": "CRITICAL",
        "pattern": "\\brm\\s+(-[a-zA-Z]*r[a-zA-Z]*f[a-zA-Z]*|-[a-zA-Z]*f[a-zA-Z]*r[a-zA-Z]*)\\s+(/|~|\\$HOME|/\\*|~/\\*)(\\s|$)",
        "reason": "Recursive force deletion targeting root or home"
      },
      {
        "id": "exec.disk-wipe",
        "severity": "CRITICAL",
        "pattern": "\\b(mkfs(\\.[a-z0-9]+)?|dd\\s+[^\\n]*of=/dev/|format\\s+[a-zA-Z]:)",
        "reason": "Disk wipe / low-level format"
      },
      {
        "id": "exec.curl-pipe-shell",
        "severity": "HIGH",
        "pattern": "\\b(curl|wget)\\b[^\\n|]*\\|\\s*(bash|sh|zsh|python[0-9.]*)",
        "reason": "Remote script piped directly into a shell interpreter"
      },
      {
        "id": "exec.fork-bomb",
        "severity": "CRITICAL",
        "pattern": ":\\(\\)\\s*\\{\\s*:\\s*\\|\\s*:\\s*&\\s*\\}\\s*;\\s*:",
        "reason": "Classic bash fork bomb"
      },
      {
        "id": "exec.system-shutdown",
        "severity": "HIGH",
        "pattern": "\\b(shutdown|reboot|halt|poweroff|init\\s+0|init\\s+6)\\b",
        "reason": "System power-state change"
      },
      {
        "id": "exec.firewall-flush",
        "severity": "HIGH",
        "pattern": "\\b(iptables|nft)\\b[^\\n]*\\s-F\\b",
        "reason": "Flushing firewall rules"
      },
      {
        "id": "exec.permission-test",
        "severity": "HIGH",
        "pattern": "\\bclawkeeper-permission-test\\b",
        "reason": "Reserved sentinel for permission persistence testing"
      },
      {
        "id": "exec.chmod-world",
        "severity": "HIGH",
        "pattern": "\\bchmod\\s+(-R\\s+)?[0-7]?777\\b",
        "reason": "Granting world-writable permissions"
      }
    ]
  }
}
